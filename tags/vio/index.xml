        <title>OpenVINS-based UAV Swarm Cooperative Self-Localization System</title>
        <link>http://localhost:1313/projects/openvins-uav-swarm/</link>
        <pubDate>Wed, 24 Apr 2024 00:00:00 +0000</pubDate>
        
        <guid>http://localhost:1313/projects/openvins-uav-swarm/</guid>
        <description>&lt;img src="http://localhost:1313/demo_video_thumbnail.jpg" alt="Featured image of post OpenVINS-based UAV Swarm Cooperative Self-Localization System" /&gt;&lt;div class=&#34;video-wrapper&#34;&gt;
